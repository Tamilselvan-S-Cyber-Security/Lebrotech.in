# Copy to Cloudflare Workers → lebrotechs → Settings → Variables (Build / Production).
# CRA bakes REACT_APP_* into the JS bundle at build time — set them BEFORE each deploy/build.
#
# Also set:
#   NODE_VERSION=20
#   CLOUDFLARE_API_TOKEN=(secret, Account → Workers Scripts → Edit)

DISABLE_ESLINT_PLUGIN=true

# Firebase
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Admin API (Vercel)
REACT_APP_ADMIN_API_URL=https://lebro-tech-api.vercel.app/api

# Internship chatbot
REACT_APP_CHATBOT_ENABLED=true
REACT_APP_CHATBOT_NAME=Internship chatbot
REACT_APP_CHATBOT_PROVIDER=auto
REACT_APP_OPENROUTER_API_KEY=
REACT_APP_OPENROUTER_MODEL=tencent/hy3:free
REACT_APP_GEMINI_API_KEY=
REACT_APP_GEMINI_MODEL=gemini-3.5-flash
REACT_APP_CHATBOT_GREETING=Hello! I am Internship chatbot. How can I help you today?
REACT_APP_CHATBOT_HUMAN_HANDOFF=If you'd like to speak with a human agent, please use the Contact page or email support@lerbotech.com.
REACT_APP_CHATBOT_COMMON_MESSAGES=Browse internships|/opportunities;Get certificate|/apply-certificate;How it works|/students;Contact support|/contact
