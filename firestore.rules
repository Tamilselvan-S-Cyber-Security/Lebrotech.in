rules_version = '2';

// Lerbo Tech — Firestore security rules (hardened).
//
// Architecture:
//   • Mock API (src/mock/server.js) is the app source of truth in the browser.
//   • Firestore mirrors writes for persistence when Firebase Auth is active.
//   • Admin console: tamilselvan@cyberwolf360.in (mock login + TOTP + Firebase email).
//
// Collections synced: users, students, startups, institutions, opportunities,
//   applications, notifications, saved_opportunities, files, login_attempts,
//   contact_enquiries, brand_settings, messages, subscription_attempts,
//   enterprise_enquiries, certificate_applications
//
// Deploy:  firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function signedIn() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function ADMIN_EMAIL() {
      return 'tamilselvan@cyberwolf360.in';
    }

    function authEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email.lower()
        : '';
    }

    function isAdmin() {
      return authEmail() == ADMIN_EMAIL();
    }

    function incoming() {
      return request.resource.data;
    }
    function current() {
      return resource.data;
    }

    function sizeOk() {
      return incoming().size() <= 100;
    }

    function noAdminEscalation() {
      return !('role' in incoming())
        || incoming().role != 'admin'
        || (('email' in incoming()) && incoming().email.lower() == ADMIN_EMAIL());
    }

    function idImmutable() {
      return !('id' in current()) || !('id' in incoming()) || incoming().id == current().id;
    }

    function createdAtImmutable() {
      return !('created_at' in current())
        || !('created_at' in incoming())
        || incoming().created_at == current().created_at;
    }

    function isEmail(v) {
      return v is string && v.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$') && v.size() <= 254;
    }

    function str(v, max) {
      return v is string && v.size() <= max;
    }

    function ownsByEmail() {
      return signedIn()
        && resource.data.email is string
        && resource.data.email.lower() == authEmail();
    }

    function safeCreate() {
      return signedIn() && sizeOk() && noAdminEscalation();
    }

    function safeUpdate() {
      return signedIn() && sizeOk() && noAdminEscalation()
        && idImmutable() && createdAtImmutable();
    }

    function adminUpdate() {
      return isAdmin() && sizeOk() && idImmutable() && createdAtImmutable();
    }

    function validCertificateCreate() {
      return sizeOk()
        && str(incoming().full_name, 120)
        && isEmail(incoming().email)
        && str(incoming().program, 120)
        && (!('interest_type' in incoming()) || str(incoming().interest_type, 32))
        && (!('certificate_type' in incoming()) || str(incoming().certificate_type, 32))
        && (!('whatsapp' in incoming()) || str(incoming().whatsapp, 32))
        && (!('status' in incoming()) || incoming().status == 'new');
    }

    function validContactCreate() {
      return sizeOk()
        && isEmail(incoming().email)
        && (!('name' in incoming()) || str(incoming().name, 120))
        && (!('message' in incoming()) || str(incoming().message, 2000))
        && (!('status' in incoming()) || incoming().status == 'new');
    }

    // ---------- identity & profiles ----------
    match /users/{doc} {
      allow read: if signedIn();
      allow create: if safeCreate();
      allow update: if safeUpdate() || adminUpdate();
      allow delete: if false;
    }
    match /students/{doc} {
      allow read: if signedIn();
      allow create: if safeCreate();
      allow update: if safeUpdate() || adminUpdate();
      allow delete: if false;
    }
    match /startups/{doc} {
      allow read: if signedIn();
      allow create: if safeCreate();
      allow update: if safeUpdate() || adminUpdate();
      allow delete: if false;
    }
    match /institutions/{doc} {
      allow read: if signedIn();
      allow create: if safeCreate();
      allow update: if safeUpdate() || adminUpdate();
      allow delete: if false;
    }

    // ---------- internships / applications ----------
    match /opportunities/{doc} {
      // Public browse (/opportunities) + signed-in dashboards.
      allow read: if true;
      allow create: if safeCreate() || (isAdmin() && sizeOk());
      allow update: if safeUpdate() || adminUpdate();
      allow delete: if isAdmin();
    }
    match /applications/{doc} {
      allow read: if signedIn();
      allow create: if safeCreate();
      allow update: if safeUpdate() || adminUpdate();
      allow delete: if false;
    }
    match /saved_opportunities/{doc} {
      allow read: if signedIn();
      allow create: if safeCreate();
      allow update: if safeUpdate();
      allow delete: if signedIn();
    }

    // ---------- public forms (guest create → admin manages) ----------
    match /certificate_applications/{doc} {
      // Guest apply form + signed-in students; admin reads/updates all in console.
      allow read: if signedIn() && (isAdmin() || ownsByEmail());
      allow create: if validCertificateCreate();
      allow update: if adminUpdate();
      allow delete: if false;
    }
    match /contact_enquiries/{doc} {
      allow read: if isAdmin();
      allow create: if validContactCreate();
      allow update: if adminUpdate();
      allow delete: if false;
    }
    match /enterprise_enquiries/{doc} {
      allow read: if isAdmin();
      allow create: if signedIn() && sizeOk();
      allow update: if adminUpdate();
      allow delete: if false;
    }

    // ---------- operational ----------
    match /notifications/{doc} {
      allow read: if signedIn();
      allow create, update: if signedIn() && sizeOk();
      allow delete: if false;
    }
    match /messages/{doc} {
      allow read: if signedIn();
      allow create, update: if signedIn() && sizeOk();
      allow delete: if false;
    }
    match /subscription_attempts/{doc} {
      allow read: if signedIn();
      allow create, update: if signedIn() && sizeOk();
      allow delete: if false;
    }
    match /login_attempts/{doc} {
      allow read: if isAdmin();
      allow create, update: if signedIn() && sizeOk();
      allow delete: if false;
    }
    match /files/{doc} {
      allow read: if signedIn();
      allow create, update: if signedIn() && sizeOk();
      allow delete: if signedIn();
    }
    match /brand_settings/{doc} {
      allow read: if signedIn();
      allow create: if isAdmin() && sizeOk() && noAdminEscalation();
      allow update: if adminUpdate();
      allow delete: if false;
    }

    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
