# Frontend-only mode — API is mocked in-browser (src/mock/).
# CRA's bundled ESLint doesn't know the React 19 rules referenced in eslint.config.js.
DISABLE_ESLINT_PLUGIN=true

# Dev server: scripts/start-dev.js picks first free port from 3001 (avoids port 3000 prompt).
PORT=3001

# Firebase Authentication (Google, GitHub, Email/Password).
# CRA only exposes variables prefixed with REACT_APP_ to the browser.
REACT_APP_FIREBASE_API_KEY=AIzaSyBYUlgHdfno6ppYj1OydRgv8fnMGnGs0Ko
REACT_APP_FIREBASE_AUTH_DOMAIN=lerbo-tech-21e2a.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=lerbo-tech-21e2a
REACT_APP_FIREBASE_STORAGE_BUCKET=lerbo-tech-21e2a.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=230938819792
REACT_APP_FIREBASE_APP_ID=1:230938819792:web:100db9e38b6a5e1644f2d5
REACT_APP_FIREBASE_MEASUREMENT_ID=G-VSDXT96KZ7

# Admin API (nodemailer + OTP + TOTP) — Vercel
REACT_APP_ADMIN_API_URL=https://lebro-tech-api.vercel.app/api
# Local override (optional): http://localhost:4000/api

# Internship chatbot (OpenRouter + Gemini)
# Provider: openrouter | gemini | auto (tries openrouter, then gemini, then local FAQ)
REACT_APP_CHATBOT_ENABLED=true
REACT_APP_CHATBOT_NAME=Internship chatbot
REACT_APP_CHATBOT_PROVIDER=auto
REACT_APP_OPENROUTER_API_KEY=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
REACT_APP_OPENROUTER_MODEL=tencent/hy3:free
REACT_APP_GEMINI_API_KEY=AQ.Ab8RN6JeWw0BrX4ylTheuZPS5hGUlbRwu94R1Sq-g0296LoAUA
REACT_APP_GEMINI_MODEL=gemini-3.5-flash
REACT_APP_CHATBOT_GREETING=Hello! I am Internship chatbot. How can I help you today?
REACT_APP_CHATBOT_HUMAN_HANDOFF=If you'd like to speak with a human agent, please use the Contact page or email support@lerbotech.com.
